// ===== ユーザー系 =====

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String
  age          Int?
  isActive     Boolean   @default(true)
  role         Role
  createdAt    DateTime  @default(now())
  internalNote String    @ignore
  profile      Profile?
  posts        Post[]
  comments     Comment[]
  orders       Order[]
}

model Profile {
  id      Int     @id @default(autoincrement())
  bio     String?
  website String?
  userId  Int     @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}
