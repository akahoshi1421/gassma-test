{
  "compilerOptions": {
    "target": "es2015",
    "module": "preserve",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "types": ["google-apps-script"]
  },
  "include": ["./src/**/*"]
}
